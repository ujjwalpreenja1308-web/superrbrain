# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI APIs
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# Scraping
FIRECRAWL_API_KEY=

# Trigger.dev
TRIGGER_SECRET_KEY=

# Dodo Payments
DODO_PAYMENTS_API_KEY=
DODO_WEBHOOK_SECRET=
# Product IDs from Dodo dashboard (one per plan × billing period)
DODO_PRODUCT_STARTER_MONTHLY=
DODO_PRODUCT_STARTER_ANNUAL=
DODO_PRODUCT_GROWTH_MONTHLY=
DODO_PRODUCT_GROWTH_ANNUAL=
DODO_PRODUCT_SCALE_MONTHLY=
DODO_PRODUCT_SCALE_ANNUAL=

# Backend
# In production, comma-separate multiple origins:
# FRONTEND_URL=https://auth.covable.app,https://home.covable.app
FRONTEND_URL=http://localhost:5173
PORT=3001

# Playwright / Chromium (production only)
# Set to http://localhost:9222 on the DO droplet
BROWSER_WS_ENDPOINT=

# Frontend (prefix with VITE_)
VITE_API_URL=http://localhost:3001
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Auth/home subdomain URLs (used for cross-domain redirects)
VITE_AUTH_URL=https://auth.covable.app
VITE_HOME_URL=https://home.covable.app
# Dodo Payments product IDs (frontend — used to build checkout URLs)
VITE_DODO_PRODUCT_STARTER_MONTHLY=
VITE_DODO_PRODUCT_STARTER_ANNUAL=
VITE_DODO_PRODUCT_GROWTH_MONTHLY=
VITE_DODO_PRODUCT_GROWTH_ANNUAL=
VITE_DODO_PRODUCT_SCALE_MONTHLY=
VITE_DODO_PRODUCT_SCALE_ANNUAL=
